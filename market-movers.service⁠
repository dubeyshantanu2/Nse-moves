[Unit]
Description=NSE Market Movers Discord Webhook Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/market_movers
EnvironmentFile=/root/market_movers/.env
ExecStart=/usr/bin/python3 /root/market_movers/bot.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
